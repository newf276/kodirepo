<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.speedtester" name="Speed Tester" version="11.1.3" provider-name="Newf276">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.script" library="resources/lib/addon_entry.py">
    <provides>executable</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="en_GB">Test your Internet bandwidth</summary>
    <description lang="en_GB">This add-on tests your Internet bandwith and reports both download and upload speeds and latency from within Kodi. Use this if you are experiencing streaming issues and you suspect your network to be the cause.</description>
    <disclaimer lang="en_GB">Speed Tester is powered by speedtest.net</disclaimer>
    <language>en</language>
    <license>Apache-2.0</license>
    <source>https://github.com/add-ons/script.speedtester</source>
    <news>v11.1.3 (2024-11-25) Add support for Python 3.9 and later</news>
    <assets>
        <icon>icon.png</icon>
        <fanart>fanart.jpg</fanart>
      <screenshot>resources/media/screenshot01.jpg</screenshot>
      <screenshot>resources/media/screenshot02.jpg</screenshot>
      <screenshot>resources/media/screenshot03.jpg</screenshot>
    </assets>
  </extension>
</addon>
